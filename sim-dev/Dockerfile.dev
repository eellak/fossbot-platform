FROM node:18-alpine

WORKDIR /app

# Install deps first (cache layer)
COPY sim-dev/package*.json ./sim-dev/
RUN cd sim-dev && npm install

# Copy sim-dev source and the simulator modules it references
COPY sim-dev/ ./sim-dev/
COPY front-end/src/components/js-simulator/ ./front-end/src/components/js-simulator/
COPY front-end/public/ ./front-end/public/

ENV CHOKIDAR_USEPOLLING=true

EXPOSE 3001

WORKDIR /app/sim-dev
CMD ["npm", "run", "dev"]
